# KIS API Configuration Example
# Copy this file to .env and fill in your actual credentials

# Required for KIS endpoints:
KIS_CANO=12345678
KIS_ACNT_PRDT_CD=01
KIS_APP_KEY=your_app_key_here
KIS_APP_SECRET=your_app_secret_here

# Use https://openapi.koreainvestment.com:9443 for Real Trading
# Use https://openapivts.koreainvestment.com:29443 for Virtual Trading
# The backend selects balance TR ID automatically:
# - TTTC8434R for real trading
# - VTTC8434R for virtual trading
KIS_URL=https://openapivts.koreainvestment.com:29443

KIS_DEBUG=false
LOG_LEVEL=INFO

# KIS rate-limit policy
# - auto: if KIS_SERVICE_APPLY_DATE is set, 신청일 포함 3일은 new-account profile, 이후 standard profile
# - new_account: 신규 실전 계정 보수 프로필 강제
# - standard: 일반 실전 계정 프로필 강제
KIS_SERVICE_APPLY_DATE=2026-04-29
KIS_RATE_LIMIT_PROFILE=auto
KIS_RATE_LIMIT_NEW_ACCOUNT_RPS=2
KIS_RATE_LIMIT_STANDARD_RPS=20
KIS_RATE_LIMIT_VIRTUAL_RPS=15

# Optional fixed override. Leave empty to keep automatic profile selection.
# KIS_RATE_LIMIT_RPS=5

# Optional fan-out override for bulk quote collection. Leave empty for profile defaults.
# KIS_BULK_CONCURRENCY=2

# Console login and local SQLite database
# Set a strong password before starting the server. This value is used only to
# create the first admin user when the users table is empty.
APP_ADMIN_USERNAME=admin
APP_ADMIN_PASSWORD=change-me-before-first-run
APP_SESSION_TTL_HOURS=12
APP_DB_PATH=data/stock_trading_bot.sqlite3

# LLM API Keys (자동매매 AI 분석용)
# fallback 순서: Anthropic → Gemini → Groq → OpenAI
# Anthropic Claude (S2 시장분석, S4 스크리닝, S5 RulePack 생성)
ANTHROPIC_API_KEY=

# Google Gemini
GEMINI_API_KEY=

# Groq (빠른 추론, 무료 티어)
GROQ_API_KEY=

# OpenAI (최후 fallback)
OPENAI_API_KEY=
